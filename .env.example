# Required from your Supabase project settings.
# Add these in Cloudflare Workers build variables/secrets too.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used by OpenNext/Wrangler local preview to load development env files.
NEXTJS_ENV=development

# Optional later for server-only maintenance scripts.
# Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=
